# =============================================
*.h5
*.keras
*.ckpt
*.onnx
*.tflite
*.pb
*.pkl
*.joblib
*.pth

# TensorFlow / Keras
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Python 数据集下载目录
data/
datasets/
logs/
models/

