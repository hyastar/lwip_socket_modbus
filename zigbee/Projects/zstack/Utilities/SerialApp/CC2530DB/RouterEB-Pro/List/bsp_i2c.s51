// E:\Coding\7 zigbee STM32\Projects\zstack\Utilities\SerialApp\Source\bsp_i2c.c
//    1 /**************************************************************************************************
//    2   Filename:       bsp_i2c.c
//    3   Revised:        $Date: 2025-10-30 $
//    4 
//    5   Description:    CC2530 软件模拟 I2C 驱动层 (BSP) 实现文件。
//    6                   (SDA: P0.5, SCL: P0.6)
//    7 **************************************************************************************************/
//    8 
//    9 /*********************************************************************
//   10  * INCLUDES
//   11  */
//   12 #include <ioCC2530.h>

        ASEGN SFR_AN:DATA:NOROOT,080H
// union <unnamed> volatile __sfr _A_P0
_A_P0:
        DATA8
        DS 1

        ASEGN SFR_AN:DATA:NOROOT,08fH
// unsigned char volatile __sfr P0INP
P0INP:
        DATA8
        DS 1

        ASEGN SFR_AN:DATA:NOROOT,0f3H
// unsigned char volatile __sfr P0SEL
P0SEL:
        DATA8
        DS 1

        ASEGN SFR_AN:DATA:NOROOT,0f7H
// unsigned char volatile __sfr P2INP
P2INP:
        DATA8
        DS 1

        ASEGN SFR_AN:DATA:NOROOT,0fdH
// unsigned char volatile __sfr P0DIR
P0DIR:
        DATA8
        DS 1
//   13 #include "bsp_i2c.h"
//   14 
//   15 /*********************************************************************
//   16  * MACROS
//   17  */
//   18 
//   19 // --- 软件 I2C 引脚定义 ---
//   20 #define SCL P0_6
//   21 #define SDA P0_5
//   22 
//   23 // --- 软件 I2C 引脚方向宏 ---
//   24 #define SDA_OUT() (P0DIR |= 0x20)  // P0.5 (SDA) 设置为输出
//   25 #define SDA_IN()  (P0DIR &= ~0x20) // P0.5 (SDA) 设置为输入
//   26 #define SCL_OUT() (P0DIR |= 0x40)  // P0.6 (SCL) 设置为输出
//   27 
//   28 /*********************************************************************
//   29  * LOCAL FUNCTIONS
//   30  */
//   31 
//   32 /**
//   33  * @brief   I2C 使用的微秒级短延时 (基于 32MHz 时钟)。
//   34  */

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   35 static void bsp_I2C_Delay(void)
bsp_I2C_Delay:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function bsp_I2C_Delay
        CODE
//   36 {
        ; Saved register size: 0
        ; Auto size: 0
//   37     // 几个 NOP 指令在 32MHz 时钟下提供足够的延时 (约 0.15us)
//   38     __asm("NOP");
        NOP
//   39     __asm("NOP");
        NOP
//   40     __asm("NOP");
        NOP
//   41     __asm("NOP");
        NOP
//   42     __asm("NOP");
        NOP
//   43 }
        LJMP    ?BRET
        CFI EndBlock cfiBlock0
//   44  
//   45 /*********************************************************************
//   46  * PUBLIC FUNCTIONS
//   47  */
//   48 
//   49 /**
//   50  * @brief   初始化软件 I2C 总线的 GPIO 引脚 (P0.5, P0.6)。
//   51  */

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   52 void bsp_I2C_Init(void)
bsp_I2C_Init:
        CFI Block cfiBlock1 Using cfiCommon0
        CFI Function bsp_I2C_Init
        CODE
//   53 {
        ; Saved register size: 0
        ; Auto size: 0
//   54     // 1. 将 P0.5 (SDA) 和 P0.6 (SCL) 设置为通用 GPIO
//   55     P0SEL &= ~0x60;
        ANL     0xf3,#0x9f
//   56     
//   57     // 2. 启用 P0 端口的上拉电阻 (通过 P2INP.0 = 0)
//   58     //    (注意: 原示例 P2INP &= ~0x02; 是 P1 端口, 这里修正为 P0)
//   59     P2INP &= ~0x01; 
        ANL     0xf7,#0xfe
//   60     
//   61     // 3. 将 P0.5 (SDA) 设置为上拉/下拉模式 (由 P2INP 控制)
//   62     //    (SDA 在 IN 模式时需要上拉)
//   63     P0INP &= ~0x20; 
        ANL     0x8f,#0xdf
//   64     
//   65     // 4. SCL 和 SDA 均设置为输出
//   66     SCL_OUT();
        ORL     0xfd,#0x40
//   67     SDA_OUT();
        ORL     0xfd,#0x20
//   68     
//   69     // 5. 设置总线空闲状态 (SCL=1, SDA=1)
//   70     SCL = 1;
        SETB    0x80.6
//   71     SDA = 1;
        SETB    0x80.5
//   72 }
        LJMP    ?BRET
        CFI EndBlock cfiBlock1
        REQUIRE P0SEL
        REQUIRE P2INP
        REQUIRE P0INP
        REQUIRE P0DIR
        REQUIRE _A_P0
//   73 
//   74 /**
//   75  * @brief   发送 I2C 起始信号。
//   76  * (SCL 高电平期间, SDA 下降沿)
//   77  */

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   78 void bsp_I2C_Start(void)
bsp_I2C_Start:
        CFI Block cfiBlock2 Using cfiCommon0
        CFI Function bsp_I2C_Start
        CODE
//   79 {
        FUNCALL bsp_I2C_Start, bsp_I2C_Delay
        LOCFRAME ISTACK, 2, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 0, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 2, STACK
