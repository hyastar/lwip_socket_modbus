//  499  * @fn      SerialApp_ProcessMSGCmd
//  500  *
//  501  * @brief   (协调器) V4.7 Zigbee 消息处理器 (单口转发模式)。
//  502  *
//  503  * @param   pkt - 指向收到的 Zigbee 消息包
//  504  *
//  505  * @return  无
//  506  */
//  507 #if defined(ZDO_COORDINATOR)
//  508 static void SerialApp_ProcessMSGCmd( afIncomingMSGPacket_t *pkt )
//  509 {
//  510   uint16 srcAddr = pkt->srcAddr.addr.shortAddr;
//  511   uint8 *payload = pkt->cmd.Data;
//  512   uint8 payloadLen = pkt->cmd.DataLength;
//  513 
//  514   // (V4.7) 2. 将原始二进制数据转发到 数据端口 (UART 0)
//  515   if ( (pkt->clusterId == SENSOR_DATA_CLUSTER) || 
//  516        (pkt->clusterId == SERIALAPP_OTA_CLUSTER) ) 
//  517   {
//  518       SendUplinkFrame(srcAddr, payload, payloadLen); // 发送到 UART 0 (V3.1 规范)
//  519   }
