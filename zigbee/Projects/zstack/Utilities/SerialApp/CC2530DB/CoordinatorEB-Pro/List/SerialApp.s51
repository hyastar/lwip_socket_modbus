        DB 0

        RSEG BANK_RELAYS:CODE:REORDER:NOROOT(0)
??SerialApp_Init?relay:
        LCALL   ?BDISPATCH
        DATA
        DC24    SerialApp_Init

        RSEG BANK_RELAYS:CODE:REORDER:NOROOT(0)
??SerialApp_ProcessEvent?relay:
        LCALL   ?BDISPATCH
        DATA
        DC24    SerialApp_ProcessEvent

        RSEG BANK_RELAYS:CODE:REORDER:NOROOT(0)
??crc16_modbus?relay:
        LCALL   ?BDISPATCH
        DATA
        DC24    crc16_modbus

        RSEG BANK_RELAYS:CODE:REORDER:NOROOT(0)
??SendUplinkFrame?relay:
        LCALL   ?BDISPATCH
        DATA
        DC24    SendUplinkFrame

        RSEG BANK_RELAYS:CODE:REORDER:NOROOT(0)
??SerialApp_UART_CB_BRIDGE?relay:
        LCALL   ?BDISPATCH
        DATA
        DC24    SerialApp_UART_CB_BRIDGE

        END
