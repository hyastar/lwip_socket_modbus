        MOV     A,R1
        MOV     R6,A
//  208   SerialApp_TaskID = task_id;
        MOV     DPTR,#SerialApp_TaskID
        MOVX    @DPTR,A
//  209   SampleApp_NwkState = DEV_INIT;       
        MOV     DPTR,#SampleApp_NwkState
        MOV     A,#0x1
        MOVX    @DPTR,A
//  210   
//  211   // ×˘˛á AF ¶Ëµă
//  212   afRegister( (endPointDesc_t *)&SerialApp_epDesc );
        ; Setup parameters for call to function afRegister
        MOV     R2,#SerialApp_epDesc & 0xff
        MOV     R3,#(SerialApp_epDesc >> 8) & 0xff
        LCALL   ??afRegister?relay
//  213 
//  214   // (V4.7) --- Đ­µ÷Ć÷: ĹäÖĂ µĄ´®żÚ (UART 0) ---
//  215 #if defined(ZDO_COORDINATOR)
//  216   {
//  217     halUARTCfg_t uartConfig;
//  218     
//  219     // --- 0. ĹäÖĂÍâÉčŇý˝ĹÓłÉä (UART 0 @ ±¸ÓĂÎ»ÖĂ 1) ---
//  220     // (U0CFG = 0, U1CFG = 0)
//  221     PERCFG &= ~0x03; // Č·±Ł UART0 şÍ UART1 ¶ĽÔÚ±¸ÓĂÎ»ÖĂ 1
        ANL     0xf1,#0xfc
//  222     
//  223     // --- 1. ĹäÖĂ ÇĹ˝ÓĘýľÝ¶ËżÚ (UART 0 @ P0.2/P0.3, 115200 ˛¨ĚŘÂĘ) ---
//  224     P0SEL |= 0x0C;   // 0b00001100: P0.2 şÍ P0.3 ÉčÖĂÎŞÍâÉčą¦ÄÜ
        ORL     0xf3,#0xc
//  225     P0DIR &= ~0x04;  // P0.2 (RXD) ÉčÖĂÎŞĘäČë
        ANL     0xfd,#0xfb
//  226     P0DIR |= 0x08;   // P0.3 (TXD) ÉčÖĂÎŞĘäłö
        ORL     0xfd,#0x8
//  227     
//  228     // (V4.7) Č·±Ł P0 ÓĹĎČÓÚ P2
//  229     P2DIR &= ~0XC0;
        ANL     0xff,#0x3f
//  230   
//  231     uartConfig.configured           = TRUE;
        MOV     DPL,?XSP + 0
        MOV     DPH,?XSP + 1
        MOV     A,#0x1
        MOVX    @DPTR,A
//  232     uartConfig.baudRate             = BRIDGE_BAUD; // (V4.7) ąŘĽü: ĐŢ¸ÄÎŞ 115200
        LCALL   ?XSTACK_DISP0_8
        MOV     A,#0x4
        MOVX    @DPTR,A
//  233     uartConfig.flowControl          = FALSE;
        MOV     A,#0x2
        LCALL   ?XSTACK_DISP0_8
        CLR     A
        MOVX    @DPTR,A
//  234     uartConfig.flowControlThreshold = 0;
        MOV     A,#0x3
        LCALL   ?XSTACK_DISP0_8
        CLR     A
        MOVX    @DPTR,A
        INC     DPTR
        MOVX    @DPTR,A
//  235     uartConfig.rx.maxBufSize        = 128;   // (V4.7) ąŘĽü: żŞĆô˝ÓĘŐ
        MOV     A,#0xa
        LCALL   ?XSTACK_DISP0_8
        MOV     A,#-0x80
        MOVX    @DPTR,A
        INC     DPTR
        CLR     A
        MOVX    @DPTR,A
//  236     uartConfig.tx.maxBufSize        = 128;
        MOV     A,#0x12
        LCALL   ?XSTACK_DISP0_8
        MOV     A,#-0x80
        MOVX    @DPTR,A
        INC     DPTR
        CLR     A
        MOVX    @DPTR,A
//  237     uartConfig.idleTimeout          = 6;
        MOV     A,#0x5
        LCALL   ?XSTACK_DISP0_8
        MOV     A,#0x6
        MOVX    @DPTR,A
//  238     uartConfig.intEnable            = TRUE;  // (V4.7) ąŘĽü: żŞĆôÖĐ¶Ď
        MOV     A,#0x16
        LCALL   ?XSTACK_DISP0_8
        MOV     A,#0x1
        MOVX    @DPTR,A
//  239     uartConfig.callBackFunc         = SerialApp_UART_CB_BRIDGE; // (V4.7) ąŘĽü: ÉčÖĂ»Řµ÷
