//   37 /**
//   38  * @brief   初始化传感器管理层和底层的驱动。
//   39  */

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   40 void Sensor_Init(uint8 task_id)
Sensor_Init:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function Sensor_Init
        CODE
//   41 {
        FUNCALL Sensor_Init, adc_mq5_Init
        LOCFRAME ISTACK, 0, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 9, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 0, STACK
        ARGFRAME PSTACK, 0, STACK
        ARGFRAME XSTACK, 9, STACK
        ARGFRAME IOVERLAY, 0, STATIC
        ARGFRAME DOVERLAY, 0, STATIC
        MOV     A,#-0x9
        LCALL   ?BANKED_ENTER_XDATA
        CFI DPH0 load(1, XDATA, add(CFA_XSP16, literal(-1)))
        CFI DPL0 load(1, XDATA, add(CFA_XSP16, literal(-2)))
        CFI ?BRET_EXT load(1, XDATA, add(CFA_XSP16, literal(-3)))
        CFI ?RET_HIGH load(1, XDATA, add(CFA_XSP16, literal(-4)))
        CFI ?RET_LOW load(1, XDATA, add(CFA_XSP16, literal(-5)))
        CFI R7 load(1, XDATA, add(CFA_XSP16, literal(-6)))
        CFI V0 load(1, XDATA, add(CFA_XSP16, literal(-7)))
        CFI VB load(1, XDATA, add(CFA_XSP16, literal(-8)))
        CFI R6 load(1, XDATA, add(CFA_XSP16, literal(-9)))
        CFI CFA_SP SP+0
        CFI CFA_XSP16 add(XSP16, 9)
        ; Saved register size: 9
        ; Auto size: 0
        MOV     A,R1
//   42   // 协调器不需要初始化任何传感器
//   43 #if !defined(ZDO_COORDINATOR)
//   44 
//   45   sensor_TaskID = task_id;
        MOV     DPTR,#sensor_TaskID
        MOVX    @DPTR,A
//   46   
//   47   // --- 根据编译时宏，调用特定驱动的初始化函数 ---
//   48   // (V3.2 更新: 所有 Init 函数现在都需要 task_id)
//   49   
//   50   #if (ACTIVE_SENSOR_TYPE == DEVICE_TYPE_SHT30)
//   51     i2c_sht30_Init(task_id);
//   52     
//   53   #elif (ACTIVE_SENSOR_TYPE == DEVICE_TYPE_MQ2)
//   54     adc_mq2_Init(task_id);
//   55     
//   56   #elif (ACTIVE_SENSOR_TYPE == DEVICE_TYPE_MQ5)
//   57     adc_mq5_Init(task_id);
        ; Setup parameters for call to function adc_mq5_Init
        LCALL   ??adc_mq5_Init?relay
//   58     
//   59   #endif
//   60   
//   61 #else
//   62   (void)task_id; 
//   63 #endif // !defined(ZDO_COORDINATOR)
//   64 }
        MOV     R7,#0x1
        LJMP    ?BANKED_LEAVE_XDATA
        CFI EndBlock cfiBlock0
//   65 
//   66 /**
//   67  * @brief   启动周期性的传感器读取定时器。
//   68  */

        RSEG BANKED_CODE:CODE:NOROOT(0)
//   69 void Sensor_StartPeriodic(void)
Sensor_StartPeriodic:
        CFI Block cfiBlock1 Using cfiCommon0
        CFI Function Sensor_StartPeriodic
        CODE
//   70 {
        FUNCALL Sensor_StartPeriodic, osal_start_timerEx
        LOCFRAME ISTACK, 2, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 0, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 2, STACK
        ARGFRAME PSTACK, 0, STACK
        ARGFRAME XSTACK, 0, STACK
        ARGFRAME IOVERLAY, 0, STATIC
        ARGFRAME DOVERLAY, 0, STATIC
        PUSH    DPL
        CFI DPL0 Frame(CFA_SP, 4)
        CFI CFA_SP SP+-4
        PUSH    DPH
        CFI DPH0 Frame(CFA_SP, 5)
        CFI CFA_SP SP+-5
        ; Saved register size: 2
        ; Auto size: 0
//   71 #if !defined(ZDO_COORDINATOR)
//   72   osal_start_timerEx(sensor_TaskID, SENSOR_READ_EVT, SENSOR_READ_PERIOD);
        ; Setup parameters for call to function osal_start_timerEx
        MOV     R4,#-0x78
        MOV     R5,#0x13
        MOV     R2,#0x4
        MOV     R3,#0x0
        MOV     DPTR,#sensor_TaskID
        MOVX    A,@DPTR
        MOV     R1,A
        LCALL   ??osal_start_timerEx?relay
        CFI EndBlock cfiBlock1
//   73 #endif
//   74 }
        REQUIRE ?Subroutine0
        ; // Fall through to label ?Subroutine0

        RSEG BANKED_CODE:CODE:NOROOT(0)
?Subroutine0:
        CFI Block cfiBlock2 Using cfiCommon0
        CFI NoFunction
        CFI CFA_SP SP+-5
        CFI DPL0 Frame(CFA_SP, 4)
        CFI DPH0 Frame(CFA_SP, 5)
        POP     DPH
        CFI CFA_SP SP+-4
        CFI DPH0 SameValue
        POP     DPL
        CFI CFA_SP SP+-3
