        CFI EndBlock cfiPicker5

        RSEG XDATA_ID:CODE:NOROOT(0)
`?<Initializer for SerialApp_epDesc>`:
        DATA8
        DB 11
        DATA16
        DW SerialApp_TaskID
        DW SerialApp_SimpleDesc
        DATA8
        DB 0

        RSEG XDATA_ID:CODE:NOROOT(0)
`?<Initializer for SerialApp_CoordAddr>`:
        DATA16
        DW 0
        DB 0, 0, 0, 0, 0, 0
        DATA8
        DB 2
        DB 11
        DB 0, 0

        RSEG BANK_RELAYS:CODE:REORDER:NOROOT(0)
??SerialApp_Init?relay:
        LCALL   ?BDISPATCH
        DATA
        DC24    SerialApp_Init

        RSEG BANK_RELAYS:CODE:REORDER:NOROOT(0)
??SerialApp_ProcessEvent?relay:
        LCALL   ?BDISPATCH
        DATA
        DC24    SerialApp_ProcessEvent

        RSEG XDATA_ROM_C:CONST:REORDER:NOROOT(0)
        DATA8
`?<Constant "EndDevice Ready (V4.9...">`:
        DB "EndDevice Ready (V4.9 UART@115200)\015\012"

        RSEG XDATA_ROM_C:CONST:REORDER:NOROOT(0)
        DATA8
`?<Constant "Network: Joined/Forme...">`:
        DB "Network: Joined/Formed (State: 0x%02X)\015\012"

        RSEG XDATA_ROM_C:CONST:REORDER:NOROOT(0)
        DATA8
`?<Constant "Network: State change...">`:
        DB "Network: State changed (State: 0x%02X)\015\012"

        RSEG XDATA_ROM_C:CONST:REORDER:NOROOT(0)
        DATA8
`?<Constant "Status: NwkState = 0x...">`:
        DB "Status: NwkState = 0x%02X\015\012"

        RSEG XDATA_ROM_C:CONST:REORDER:NOROOT(0)
        DATA8
`?<Constant "Sensor: Local SHT30, ...">`:
        DB "Sensor: Local SHT30, Temp: %dC, Humi: %d%%\015\012\015\012"

        RSEG XDATA_ROM_C:CONST:REORDER:NOROOT(0)
        DATA8
`?<Constant "Sensor: Local MQx (0x...">`:
        DB "Sensor: Local MQx (0x%02X), ADC: %u\015\012\015\012"

        RSEG XDATA_ROM_C:CONST:REORDER:NOROOT(0)
        DATA8
`?<Constant "Sensor: Local Unknown...">`:
        DB "Sensor: Local Unknown (0x%02X), Len: %d\015\012\015\012"

        END
