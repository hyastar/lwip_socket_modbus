        RSEG BANKED_CODE:CODE:NOROOT(0)
//  206 void SerialApp_Init( uint8 task_id )
SerialApp_Init:
        CFI Block cfiBlock0 Using cfiCommon0
        CFI Function SerialApp_Init
        CODE
//  207 {
        FUNCALL SerialApp_Init, afRegister
        LOCFRAME ISTACK, 0, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 38, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 0, STACK
        ARGFRAME PSTACK, 0, STACK
        ARGFRAME XSTACK, 38, STACK
        ARGFRAME IOVERLAY, 0, STATIC
        ARGFRAME DOVERLAY, 0, STATIC
        FUNCALL SerialApp_Init, HalUARTOpen
        LOCFRAME ISTACK, 0, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 38, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 0, STACK
        ARGFRAME PSTACK, 0, STACK
        ARGFRAME XSTACK, 38, STACK
        ARGFRAME IOVERLAY, 0, STATIC
        ARGFRAME DOVERLAY, 0, STATIC
        FUNCALL SerialApp_Init, HalUARTWrite
        LOCFRAME ISTACK, 0, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 38, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 0, STACK
        ARGFRAME PSTACK, 0, STACK
        ARGFRAME XSTACK, 38, STACK
        ARGFRAME IOVERLAY, 0, STATIC
        ARGFRAME DOVERLAY, 0, STATIC
        FUNCALL SerialApp_Init, Sensor_Init
        LOCFRAME ISTACK, 0, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 38, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 0, STACK
        ARGFRAME PSTACK, 0, STACK
        ARGFRAME XSTACK, 38, STACK
        ARGFRAME IOVERLAY, 0, STATIC
        ARGFRAME DOVERLAY, 0, STATIC
        MOV     A,#-0x9
        LCALL   ?BANKED_ENTER_XDATA
        CFI DPH0 load(1, XDATA, add(CFA_XSP16, literal(-1)))
        CFI DPL0 load(1, XDATA, add(CFA_XSP16, literal(-2)))
        CFI ?BRET_EXT load(1, XDATA, add(CFA_XSP16, literal(-3)))
        CFI ?RET_HIGH load(1, XDATA, add(CFA_XSP16, literal(-4)))
        CFI ?RET_LOW load(1, XDATA, add(CFA_XSP16, literal(-5)))
        CFI R7 load(1, XDATA, add(CFA_XSP16, literal(-6)))
        CFI V0 load(1, XDATA, add(CFA_XSP16, literal(-7)))
        CFI VB load(1, XDATA, add(CFA_XSP16, literal(-8)))
        CFI R6 load(1, XDATA, add(CFA_XSP16, literal(-9)))
        CFI CFA_SP SP+0
        CFI CFA_XSP16 add(XSP16, 9)
        ; Saved register size: 9
        ; Auto size: 29
        MOV     A,#-0x1d
        LCALL   ?ALLOC_XSTACK8
        CFI CFA_XSP16 add(XSP16, 38)
        MOV     A,R1
        MOV     R6,A
//  208   SerialApp_TaskID = task_id;
        MOV     DPTR,#SerialApp_TaskID
        MOVX    @DPTR,A
//  209   SampleApp_NwkState = DEV_INIT;       
        MOV     DPTR,#SampleApp_NwkState
        MOV     A,#0x1
        MOVX    @DPTR,A
//  210   
//  211   // зЂВс AF ЖЫЕу
//  212   afRegister( (endPointDesc_t *)&SerialApp_epDesc );
        ; Setup parameters for call to function afRegister
        MOV     R2,#SerialApp_epDesc & 0xff
        MOV     R3,#(SerialApp_epDesc >> 8) & 0xff
        LCALL   ??afRegister?relay
//  213 
//  214   // (V4.7) --- а­ЕїЦї: ХфжУ ЕЅДЎПк (UART 0) ---
//  215 #if defined(ZDO_COORDINATOR)
//  216   {
//  217     halUARTCfg_t uartConfig;
//  218     
//  219     // --- 0. ХфжУЭтЩшв§НХгГЩф (UART 0 @ БИгУЮЛжУ 1) ---
//  220     // (U0CFG = 0, U1CFG = 0)
//  221     PERCFG &= ~0x03; // ШЗБЃ UART0 КЭ UART1 ЖМдкБИгУЮЛжУ 1
//  222     
//  223     // --- 1. ХфжУ ЧХНгЪ§ОнЖЫПк (UART 0 @ P0.2/P0.3, 115200 ВЈЬиТЪ) ---
//  224     P0SEL |= 0x0C;   // 0b00001100: P0.2 КЭ P0.3 ЩшжУЮЊЭтЩшЙІФм
//  225     P0DIR &= ~0x04;  // P0.2 (RXD) ЩшжУЮЊЪфШы
//  226     P0DIR |= 0x08;   // P0.3 (TXD) ЩшжУЮЊЪфГі
//  227     
//  228     // (V4.7) ШЗБЃ P0 гХЯШгк P2
//  229     P2DIR &= ~0XC0;
//  230   
//  231     uartConfig.configured           = TRUE;
//  232     uartConfig.baudRate             = BRIDGE_BAUD; // (V4.7) ЙиМќ: аоИФЮЊ 115200
//  233     uartConfig.flowControl          = FALSE;
//  234     uartConfig.flowControlThreshold = 0;
//  235     uartConfig.rx.maxBufSize        = 128;   // (V4.7) ЙиМќ: ПЊЦєНгЪе
//  236     uartConfig.tx.maxBufSize        = 128;
//  237     uartConfig.idleTimeout          = 6;
//  238     uartConfig.intEnable            = TRUE;  // (V4.7) ЙиМќ: ПЊЦєжаЖЯ
//  239     uartConfig.callBackFunc         = SerialApp_UART_CB_BRIDGE; // (V4.7) ЙиМќ: ЩшжУЛиЕї
//  240     HalUARTOpen (SERIAL_APP_PORT, &uartConfig); // ДђПЊ UART 0
//  241     
//  242     
//  243     // (V4.3) ЦєЖЏ V3.1 ЙцЗЖаФЬјЖЈЪБЦї
//  244     osal_start_timerEx(SerialApp_TaskID, HEARTBEAT_EVT, 5000);
//  245   }
//  246   
//  247   // (V4.9) --- жеЖЫ/ТЗгЩ: ХфжУ ЕїЪд UART (UART 0) @ 115200 ---
//  248 #else 
//  249   {
//  250     halUARTCfg_t uartConfig;
//  251   
//  252     // ТЗгЩ/жеЖЫ ЭГвЛЪЙгУ 115200 ВЈЬиТЪ
//  253     uartConfig.configured           = TRUE;
        MOV     DPL,?XSP + 0
        MOV     DPH,?XSP + 1
        MOV     A,#0x1
        MOVX    @DPTR,A
//  254     uartConfig.baudRate             = BRIDGE_BAUD; 
        LCALL   ?XSTACK_DISP0_8
        MOV     A,#0x4
        MOVX    @DPTR,A
//  255     uartConfig.flowControl          = FALSE;
        MOV     A,#0x2
        LCALL   ?XSTACK_DISP0_8
        CLR     A
        MOVX    @DPTR,A
//  256     uartConfig.flowControlThreshold = 0;
        MOV     A,#0x3
        LCALL   ?XSTACK_DISP0_8
        CLR     A
        MOVX    @DPTR,A
        INC     DPTR
        MOVX    @DPTR,A
//  257     uartConfig.rx.maxBufSize        = 0; // НкЕуФЌШЯВЛНгЪеДЎПкЪ§Он
        MOV     A,#0xa
        LCALL   ?XSTACK_DISP0_8
        CLR     A
        MOVX    @DPTR,A
        INC     DPTR
        MOVX    @DPTR,A
//  258     uartConfig.tx.maxBufSize        = 128;
        MOV     A,#0x12
        LCALL   ?XSTACK_DISP0_8
        MOV     A,#-0x80
        MOVX    @DPTR,A
        INC     DPTR
        CLR     A
        MOVX    @DPTR,A
//  259     uartConfig.idleTimeout          = 6;
        MOV     A,#0x5
        LCALL   ?XSTACK_DISP0_8
        MOV     A,#0x6
        MOVX    @DPTR,A
//  260     uartConfig.intEnable            = FALSE;
        MOV     A,#0x16
        LCALL   ?XSTACK_DISP0_8
        CLR     A
        MOVX    @DPTR,A
//  261     uartConfig.callBackFunc         = NULL; 
        MOV     A,#0x1b
        LCALL   ?XSTACK_DISP0_8
        CLR     A
        MOVX    @DPTR,A
        INC     DPTR
        MOVX    @DPTR,A
//  262     HalUARTOpen (SERIAL_APP_PORT, &uartConfig);
        ; Setup parameters for call to function HalUARTOpen
        MOV     DPL,?XSP + 0
        MOV     DPH,?XSP + 1
        MOV     R2,DPL
        MOV     R3,DPH
        MOV     R1,A
        LCALL   ??HalUARTOpen?relay
//  263   }
//  264 #endif // ZDO_COORDINATOR
//  265 
//  266   
//  267   //  --- вЦГ§Ыљгаа­ЕїЦїЕФЦєЖЏДђгЁаХЯЂ ---
//  268   #if defined(ZDO_COORDINATOR)
//  269     // HalUARTWrite(SERIAL_APP_PORT, (uint8*)"Coordinator Ready (V4.7 Single UART)\r\n", 39);
//  270   #elif defined(ZDO_ENDDEVICE)
//  271     //  ТЗгЩ/жеЖЫЕФДђгЁаХЯЂЪЧБЃСєЕФ
//  272     HalUARTWrite(SERIAL_APP_PORT, (uint8*)"EndDevice Ready (V4.9 UART@115200)\r\n", 36);
