//  521 
//  522 // =================================================================
//  523 // --- (V4.7) а­ЕїЦї СДТЗ B (V3.1 ЙцЗЖ) ЪЕЯжКЏЪ§ (ШЋВПзп UART 0) ---
//  524 // =================================================================
//  525 #if defined(ZDO_COORDINATOR)
//  526 
//  527 /**
//  528  * @brief (V4.3) V3.1 ЙцЗЖ: CRC-16/MODBUS МЦЫу
//  529  * [cite: STM32-ZigbeeЛьКЯЭЈаХЙцЗЖV3.1(OTA).md, section 3.6]
//  530  */
//  531 static uint16 crc16_modbus(const uint8 *data, uint16 len) 
//  532 {
//  533     uint16 crc = 0xFFFF;
//  534     for (uint16 i = 0; i < len; i++) {
//  535         uint8 index = (uint8)(crc ^ data[i]);
//  536         crc = (crc >> 8) ^ crc16_table[index];
//  537     }
//  538     return crc;
//  539 }
//  540 
//  541 /**
//  542  * @brief (V4.3) Яђ STM32 ЗЂЫЭЩЯаажЁ (ЗтзА СДТЗ B)
//  543  * [cite: STM32-ZigbeeЛьКЯЭЈаХЙцЗЖV3.1(OTA).md, section 4.2.1]
//  544  */
//  545 static void SendUplinkFrame(uint16 srcAddr, uint8 *payload, uint8 payloadLen)
//  546 {
//  547     // жЁЛКГхЧј: SOF(1) + SRC(2) + LEN(1) + Payload(N) + CRC(2)
//  548     uint8 frame[256];
//  549     uint16 crc;
//  550     uint8 frameLen;
//  551     
//  552     // 1. МьВщГЄЖШЪЧЗёвчГі (Payload зюДѓ 256-6=250 зжНк)
//  553     if (payloadLen > (256 - 6))
//  554     {
//  555       return; 
//  556     }
//  557 
//  558     // 2. ЙЙдьжЁЭЗ
//  559     frame[0] = 0xAA; // SOF
//  560     frame[1] = (srcAddr >> 8) & 0xFF; // SRC_H
//  561     frame[2] = srcAddr & 0xFF; // SRC_L
//  562     frame[3] = payloadLen; // LEN
//  563     
//  564     // 3. ПНБД Payload (ЭъећЕФ СДТЗ A TLV НсЙЙ)
//  565     if (payloadLen > 0)
//  566     {
//  567       osal_memcpy(&frame[4], payload, payloadLen);
//  568     }
//  569     
//  570     // 4. МЦЫу CRC (Дг SRC_H ЕН Payload ФЉЮВ, ЙВ 3+N зжНк)
//  571     // [cite: STM32-ZigbeeЛьКЯЭЈаХЙцЗЖV3.1(OTA).md, section 3.2]
//  572     crc = crc16_modbus(&frame[1], 3 + payloadLen);
//  573     
//  574     // 5. ЬюГф CRC
//  575     frameLen = 4 + payloadLen;
//  576     frame[frameLen++] = crc & 0xFF; // CRC_L
//  577     frame[frameLen++] = (crc >> 8) & 0xFF; // CRC_H
//  578     
//  579     // 6. (V4.7) ЙиМќ: ЗЂЫЭЕНЧХНгЪ§ОнЖЫПк UART 0
//  580     HalUARTWrite(SERIAL_APP_PORT, frame, frameLen);
//  581 }
//  582 
//  583 /**
//  584  * @brief (V4.3) Яђ STM32 ЗЂЫЭаФЬјжЁ (ЗтзА СДТЗ B)
//  585  * [cite: STM32-ZigbeeЛьКЯЭЈаХЙцЗЖV3.1(OTA).md, section 4.2.3]
//  586  */
//  587 static void SendHeartbeat(void)
//  588 {
//  589     uint8 frame[6];
//  590     uint16 crc;
//  591     
//  592     frame[0] = 0xAA; // SOF
//  593     frame[1] = 0x00; // SRC_H = 0x00
//  594     frame[2] = 0x00; // SRC_L = 0x00 (а­ЕїЦїЕижЗ)
//  595     frame[3] = 0x00; // LEN = 0 (Юо Payload)
//  596     
//  597     // МЦЫу CRC (МЦЫу 3 зжНк: SRC_H, SRC_L, LEN)
//  598     // [cite: STM32-ZigbeeЛьКЯЭЈаХЙцЗЖV3.1(OTA).md, section 3.4]
//  599     crc = crc16_modbus(&frame[1], 3);
//  600     frame[4] = crc & 0xFF;
//  601     frame[5] = (crc >> 8) & 0xFF;
//  602     
//  603     // (V4.7) ЙиМќ: ЗЂЫЭЕНЧХНгЪ§ОнЖЫПк UART 0
//  604     HalUARTWrite(SERIAL_APP_PORT, frame, 6);
//  605 }
//  606 
//  607 /**
//  608  * @brief (V4.7) UART НгЪеЛиЕїКЏЪ§ (еМЮЛЗћ, зЈгУгк UART 0)
//  609  * [cite: STM32-ZigbeeЛьКЯЭЈаХЙцЗЖV3.1(OTA).md, section 4.2.2]
//  610  */
//  611 static void SerialApp_UART_CB_BRIDGE(uint8 port, uint8 event)
//  612 {
//  613   (void)port;
//  614   (void)event;
//  615   
//  616   // (V4.7) еМЮЛЗћ: 
