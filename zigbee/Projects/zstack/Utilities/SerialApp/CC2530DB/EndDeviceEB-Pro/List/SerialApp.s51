//  497  * @fn      SerialApp_ProcessMSGCmd
//  498  *
//  499  * @brief   (а­ЕїЦї) V4.7 Zigbee ЯћЯЂДІРэЦї (ЕЅПкзЊЗЂФЃЪН)ЁЃ
//  500  *
//  501  * @param   pkt - жИЯђЪеЕНЕФ Zigbee ЯћЯЂАќ
//  502  *
//  503  * @return  Юо
//  504  */
//  505 #if defined(ZDO_COORDINATOR)
//  506 static void SerialApp_ProcessMSGCmd( afIncomingMSGPacket_t *pkt )
//  507 {
//  508   uint16 srcAddr = pkt->srcAddr.addr.shortAddr;
//  509   uint8 *payload = pkt->cmd.Data;
//  510   uint8 payloadLen = pkt->cmd.DataLength;
//  511 
//  512   // (V4.7) 2. НЋд­ЪМЖўНјжЦЪ§ОнзЊЗЂЕН Ъ§ОнЖЫПк (UART 0)
//  513   if ( (pkt->clusterId == SENSOR_DATA_CLUSTER) || 
//  514        (pkt->clusterId == SERIALAPP_OTA_CLUSTER) ) 
//  515   {
